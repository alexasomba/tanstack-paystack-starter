{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tanstack-paystack-starter",
  "compatibility_date": "2026-02-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "vars": {
    "VITE_BETTER_AUTH_URL": "https://your-deployed-url.workers.dev",
    "BETTER_AUTH_URL": "https://your-deployed-url.workers.dev",
    "URL": "https://your-deployed-url.workers.dev"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  }
}
